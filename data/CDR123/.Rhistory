colnames(J.TRB) <- c("cdr3", "ext")
rownames(J.TRB) <- names(J.TRB.cdr3)
write.csv(J.TRA, file=paste("TRAJ_CDR3",allele,".csv",sep=""), quote=F)
write.csv(J.TRB, file=paste("TRBJ_CDR3",allele,".csv",sep=""), quote=F)
}
