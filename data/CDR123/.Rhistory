fr.lst[is.na(fr.lst)] <- 0
N.lst[is.na(N.lst)] <- 0
m.f <- cbind(cdr123[,c(1,2,3)],N.lst,fr.lst,mult.lst)
colnames(m.f) <- c("Allele", "CDR1", "CDR2", "iReceptor_occurence","iReceptor_freq_allele", "Mult_CDR12")
write.csv(m.f, file="allele_freq_mult_cdr12.csv", quote=F)
