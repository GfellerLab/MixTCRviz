map_cdr <- function(p, x, allele){
str <- unlist(lapply(names(x), function(y){unlist(strsplit(y, split="|", fixed=T))[2]}))
if(allele=="yes"){
nm <- unlist(lapply(str, function(y){unlist(strsplit(y, split="*", fixed=T))[1]}))
} else {
nm <- str
}
list.nm <- unique(nm)
#Remove positions that have only gaps
p2 <- c()
for(pos in p){
a <- unique(unlist(lapply(x, function(y){y[pos]})))
if(length(a) > 1){
p2 <- c(p2,pos)
} else {
if(a != "-"){
p2 <- c(p2,pos)
}
}
}
r1 <- as.character(unlist(lapply(x, function(y){st <- y[p2]; st <- st[!is.na(st)]; paste(st, collapse="")})))
seq <- rep("", length(list.nm))
names(seq) <- list.nm
for(s in list.nm){
ind <- which(nm==s)
seq[s] <- r1[ind[1]]
}
return(seq)
}
map_J <- function(p, t, x){
s <- unlist(lapply(names(x), function(y){unlist(strsplit(y, split="|", fixed=T))[2]}))
if(allele=="yes"){
nm <- unlist(lapply(s, function(y){unlist(strsplit(y, split="*", fixed=T))[1]}))
} else {
nm <- str
}
list.nm <- unique(nm)
r1 <- as.character(unlist(lapply(x, function(y){ paste(y[p+length(y)-t], collapse="")  })))
seq <- rep("", length(list.nm))
names(seq) <- list.nm
for(s in list.nm){
ind <- which(nm==s)
seq[s] <- r1[ind[1]]
}
return(seq)
}
