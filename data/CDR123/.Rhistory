}
library(seqinr)
#Extract the CDR1 and CDR2 sequences, including gaps.
map_cdr <- function(p, x, allele){
str <- unlist(lapply(names(x), function(y){unlist(strsplit(y, split="|", fixed=T))[2]}))
if(allele=="yes"){
nm <- unlist(lapply(str, function(y){unlist(strsplit(y, split="*", fixed=T))[1]}))
} else {
nm <- str
}
list.nm <- unique(nm)
#Remove positions that have only gaps
p2 <- c()
for(pos in p){
a <- unique(unlist(lapply(x, function(y){y[pos]})))
if(length(a) > 1){
p2 <- c(p2,pos)
} else {
if(a != "-"){
p2 <- c(p2,pos)
}
}
}
r1 <- as.character(unlist(lapply(x, function(y){st <- y[p2]; st <- st[!is.na(st)]; paste(st, collapse="")})))
seq <- rep("", length(list.nm))
names(seq) <- list.nm
for(s in list.nm){
ind <- which(nm==s)
seq[s] <- r1[ind[1]]
}
return(seq)
}
map_J <- function(p, t, x, allele){
s <- unlist(lapply(names(x), function(y){unlist(strsplit(y, split="|", fixed=T))[2]}))
if(allele=="yes"){
nm <- unlist(lapply(s, function(y){unlist(strsplit(y, split="*", fixed=T))[1]}))
} else {
nm <- str
}
list.nm <- unique(nm)
r1 <- as.character(unlist(lapply(x, function(y){ paste(y[p+length(y)-t], collapse="")  })))
seq <- rep("", length(list.nm))
names(seq) <- list.nm
for(s in list.nm){
ind <- which(nm==s)
seq[s] <- r1[ind[1]]
}
return(seq)
}
### Load the aligned sequences of CDR1 and CDR2
TRAV.seq <- read.fasta("../TRAV_HomoSapiens.fasta", seqtype="AA")
cdr1.pos.TRA <- 27:38
cdr2.pos.TRA <- 56:65
cdr3.pos.TRA <- 104:107
TRBV.seq <- read.fasta("../TRBV_HomoSapiens.fasta", seqtype="AA")
cdr1.pos.TRB <- 27:38
cdr2.pos.TRB <- 56:65
cdr3.pos.TRB <- 104:107
allele.type <- c("yes", "no")
file=c("","_allele")
names(file)=allele
for(a in allele.type){
cdr1.TRA <- map_cdr(cdr1.pos.TRA, TRAV.seq, a)
cdr2.TRA <- map_cdr(cdr2.pos.TRA, TRAV.seq, a)
cdr3.TRA <- map_cdr(cdr3.pos.TRA, TRAV.seq, a)
cdr1.TRB <- map_cdr(cdr1.pos.TRB, TRBV.seq, a)
cdr2.TRB <- map_cdr(cdr2.pos.TRB, TRBV.seq, a)
cdr3.TRB <- map_cdr(cdr3.pos.TRB, TRBV.seq, a)
#Extract CDR1, CDR2 and CDR3 sequences from V and J genes
cdr123.TRA <- matrix(c(cdr1.TRA, cdr2.TRA, cdr3.TRA), ncol=3)
colnames(cdr123.TRA) <- c("cdr1", "cdr2", "cdr3")
rownames(cdr123.TRA) <- names(cdr1.TRA)
write.csv(cdr123.TRA, file=paste("TRAV_CDR123",file[a],".csv", sep=""), quote=F)
cdr123.TRB <- matrix(c(cdr1.TRB, cdr2.TRB, cdr3.TRB), ncol=3)
colnames(cdr123.TRB) <- c("cdr1", "cdr2", "cdr3")
rownames(cdr123.TRB) <- names(cdr1.TRB)
write.csv(cdr123.TRB, file=paste("TRBV_CDR123",file[a],".csv", sep=""), quote=F)
}
#Extract the TRAJ sequence
TRAJ.seq <- read.fasta("../TRAJ_HomoSapiens.fasta", seqtype="AA")
TRBJ.seq <- read.fasta("../TRBJ_HomoSapiens.fasta", seqtype="AA")
J.pos.TRA <- 1:4
J.ext.TRA <- 5:7
J.offset.TRA <- 14 # The start is defined as 4aa before the conserved G.
J.pos.TRB <- 1:4
J.ext.TRB <- 5:7
J.offset.TRB <- 13 # The start is defined as 4aa before the conserved G.
for(a in allele.type){
J.TRA.cdr3 <- map_J(J.pos.TRA, J.offset.TRA, TRAJ.seq,a)
J.TRA.ext <- map_J(J.ext.TRA, J.offset.TRA, TRAJ.seq,a)
J.TRB.cdr3 <- map_J(J.pos.TRB, J.offset.TRB, TRBJ.seq,a)
J.TRB.ext <- map_J(J.ext.TRB, J.offset.TRB, TRBJ.seq,a)
J.TRA <- matrix(c(J.TRA.cdr3, J.TRA.ext), ncol=2)
colnames(J.TRA) <- c("cdr3", "ext")
rownames(J.TRA) <- names(J.TRA.cdr3)
J.TRB <- matrix(c(J.TRB.cdr3, J.TRB.ext), ncol=2)
colnames(J.TRB) <- c("cdr3", "ext")
rownames(J.TRB) <- names(J.TRB.cdr3)
write.csv(J.TRA, file=paste("TRAJ_CDR3",file[a],".csv",sep=""), quote=F)
write.csv(J.TRB, file=paste("TRBJ_CDR3",file[a],".csv",sep=""), quote=F)
}
